VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# YouTube Data API v3 — opt-in only; app uses TheMealDB/Piped by default (no quota burn)
# YOUTUBE_SEARCH_ENABLED=1
YOUTUBE_API_KEY=

GROQ_API_KEY=
HUGGINGFACE_TOKEN=

# Supabase service role — required for diet media cache persistence + AI audit log
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Native app + external API auth (set same key in EXPO_PUBLIC_MEDORA_AI_KEY)
MEDORA_AI_API_KEY=generate-a-random-secret

# HIPAA / compliance (defaults are production-safe)
MEDORA_AI_PHI_REDACTION=true
MEDORA_AI_ALLOW_CLOUD_PHI=false
MEDORA_AI_REQUIRE_BAA=true
MEDORA_AI_BAA_GEMINI=true
MEDORA_AI_BAA_GROQ=false
MEDORA_AI_BAA_HUGGINGFACE=false
MEDORA_AI_AUDIT_LOG=true

# Legacy client fallback only (not recommended)
# VITE_HUGGINGFACE_TOKEN=
